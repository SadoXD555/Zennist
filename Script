local isVerifying = false

local function VerifyKey()
    if isVerifying then return end
    local inputKey = keyInput.Text:gsub("%s", "")
    if inputKey == "" then
        keyStatus.Text      = "Please enter a key"
        keyStatus.TextColor3 = C.red
        return
    end
    isVerifying          = true
    keyStatus.Text       = "Verifying"
    keyStatus.TextColor3 = C.subtext
    keyLoading.Text      = "Connecting to database"
    keySubmit.Text       = "Verifying"

    task.spawn(function()
        local dbPath = "keys/" .. keyToPath(inputKey)
        local data   = firebaseGet(dbPath)

        if type(data) ~= "table" then
            keyStatus.Text       = "Invalid key"
            keyStatus.TextColor3 = C.red
            keyLoading.Text      = ""
            keySubmit.Text       = "Verify Key"
            isVerifying          = false
            return
        end
        if data.blacklisted == true then
            keyStatus.Text       = "Key is blacklisted"
            keyStatus.TextColor3 = C.red
            keyLoading.Text      = ""
            keySubmit.Text       = "Verify Key"
            isVerifying          = false
            return
        end
        if type(data.expires_at) == "string" and data.expires_at ~= "" then
            local y, mo, d, h, mi, s = data.expires_at:match("(%d+)-(%d+)-(%d+) (%d+):(%d+):(%d+)")
            if y then
                local expireTime = os.time({
                    year  = tonumber(y),
                    month = tonumber(mo),
                    day   = tonumber(d),
                    hour  = tonumber(h),
                    min   = tonumber(mi),
                    sec   = tonumber(s),
                })
                if os.time() > expireTime then
                    keyStatus.Text       = "Key expired"
                    keyStatus.TextColor3 = C.red
                    keyLoading.Text      = ""
                    keySubmit.Text       = "Verify Key"
                    isVerifying          = false
                    return
                end
            end
        end
        local currentHWID = getHWID()
        local savedHWID   = data.hwid
        if not savedHWID or savedHWID == "" or savedHWID == false then
            firebasePatch(dbPath, { hwid = currentHWID })
        else
            if tostring(savedHWID) ~= tostring(currentHWID) then
                keyStatus.Text       = "HWID mismatch - Reset at Discord"
                keyStatus.TextColor3 = C.red
                keyLoading.Text      = ""
                keySubmit.Text       = "Verify Key"
                isVerifying          = false
                return
            end
        end

        keyStatus.Text       = "Key verified!"
        keyStatus.TextColor3 = C.green
        keyLoading.Text      = ""
        keySubmit.Text       = "Success"
        task.wait(0.6)
        ShowMapScreen()
        isVerifying = false
    end)
end

keySubmit.MouseButton1Click:Connect(VerifyKey)
keyInput.FocusLost:Connect(function(enter)
    if enter then VerifyKey() end
end)

task.spawn(function()
    task.wait(0.1)
    local autoKey = tostring(_G.Key or ""):gsub("%s", "")
    if autoKey ~= "" then
        keyInput.Text = autoKey
        VerifyKey()
    end
end)
