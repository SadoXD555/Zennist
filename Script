-- ESP functions
local function IsTeammate(plr)
    return teamCheckEnabled
        and Players.LocalPlayer.Team ~= nil
        and plr.Team ~= nil
        and plr.Team == Players.LocalPlayer.Team
end
local function AddHL(name, adornee, color)
    local h = Storage:FindFirstChild(name)
    if h then h.FillColor = color return end
    h = Instance.new("Highlight")
    h.Name               = name
    h.FillColor          = color
    h.DepthMode          = "AlwaysOnTop"
    h.FillTransparency   = 0.5
    h.OutlineColor       = Color3.new(1, 1, 1)
    h.OutlineTransparency = 0
    h.Adornee            = adornee
    h.Parent             = Storage
end
local function RemHL(name)
    local h = Storage:FindFirstChild(name)
    if h then h:Destroy() end
end
local function RefreshPlayerColors()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Players.LocalPlayer then
            local h = Storage:FindFirstChild("P_" .. plr.Name)
            if h then
                h.FillColor = IsTeammate(plr) and FillColorTeammate or FillColorPlayer
            end
        end
    end
end
local function HighlightPlayer(plr)
    if plr == Players.LocalPlayer then return end
    if plr.Character and espPlayerEnabled then
        AddHL("P_"..plr.Name, plr.Character, IsTeammate(plr) and FillColorTeammate or FillColorPlayer)
    end
    espConnections[plr] = plr.CharacterAdded:Connect(function(char)
        RemHL("P_"..plr.Name)
        task.wait()
        if espPlayerEnabled then
            AddHL("P_"..plr.Name, char, IsTeammate(plr) and FillColorTeammate or FillColorPlayer)
        end
    end)
end
local function ScanNPCs()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid")
            and not Players:GetPlayerFromCharacter(obj) then
            local id = "NPC_" .. obj:GetDebugId()
            if not npcCache[id] then
                npcCache[id] = true
                AddHL(id, obj, FillColorNPC)
                obj.AncestryChanged:Connect(function()
                    if not obj:IsDescendantOf(workspace) then
                        npcCache[id] = nil
                        RemHL(id)
                    end
                end)
            end
        end
    end
end

