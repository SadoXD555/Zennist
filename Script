RunService.RenderStepped:Connect(function(dt)
    if math.abs(espFadeAlpha - espFadeTarget) > 0.002 then
        espFadeAlpha = espFadeAlpha + (espFadeTarget - espFadeAlpha) * math.min(1, dt * 9)
        espFrame.GroupTransparency = espFadeAlpha
