-- HWID
local function getHWID()
    local ok, hwid = pcall(function()
        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    if ok and hwid and hwid ~= "" then return hwid end
    return tostring(Client.UserId)
end

-- Firebase GET
local function firebaseGet(path)
    local url = DATABASE_URL .. "/" .. path .. ".json"
    local ok, res = pcall(game.HttpGet, game, url)
    if not ok or not res then return nil end
    local ok2, decoded = pcall(HttpService.JSONDecode, HttpService, res)
    if ok2 then return decoded end
    return nil
end

-- Firebase PATCH
local function firebasePatch(path, data)
    local url     = DATABASE_URL .. "/" .. path .. ".json"
    local body    = HttpService:JSONEncode(data)
    local headers = { ["Content-Type"] = "application/json" }
    local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request or nil
    if requestFunc then
        pcall(requestFunc, { Url = url, Method = "PATCH", Headers = headers, Body = body })
    else
        pcall(function()
            HttpService:RequestAsync({ Url = url, Method = "PUT", Headers = headers, Body = body })
        end)
    end
end

