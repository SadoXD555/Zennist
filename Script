-- Drag
local dragging       = false
local dragStartMouse = Vector2.new()
local dragStartFrame = Vector2.new()
local targetPos      = Vector2.new(16, 200)

espTitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging       = true
        dragStartMouse = Vector2.new(input.Position.X, input.Position.Y)
        dragStartFrame = Vector2.new(espFrame.Position.X.Offset, espFrame.Position.Y.Offset)
        targetPos      = dragStartFrame
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
RunService.RenderStepped:Connect(function(dt)
    if dragging then
        local mouse  = UserInputService:GetMouseLocation()
        local delta  = mouse - dragStartMouse
        local screen = workspace.CurrentCamera.ViewportSize
        targetPos = Vector2.new(
            math.clamp(dragStartFrame.X + delta.X, 0, screen.X - espFrame.AbsoluteSize.X),
            math.clamp(dragStartFrame.Y + delta.Y, 0, screen.Y - espFrame.AbsoluteSize.Y)
        )
    end
    local cur    = Vector2.new(espFrame.Position.X.Offset, espFrame.Position.Y.Offset)
    local speed  = dragging and 18 or 10
    local lerped = cur:Lerp(targetPos, math.min(1, dt * speed))
    espFrame.Position = UDim2.new(0, lerped.X, 0, lerped.Y)
end)

