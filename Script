-- Ripple
local function MakeRipple(btn)
    local mouse = UserInputService:GetMouseLocation()
    local abs   = btn.AbsolutePosition
    local r     = Instance.new("Frame")
    r.Size                    = UDim2.new(0, 0, 0, 0)
    r.Position                = UDim2.new(0, mouse.X - abs.X, 0, mouse.Y - abs.Y)
    r.AnchorPoint             = Vector2.new(0.5, 0.5)
    r.BackgroundColor3        = Color3.fromRGB(255, 255, 255)
    r.BackgroundTransparency  = 0.82
    r.BorderSizePixel         = 0
    r.ZIndex                  = 20
    r.ClipsDescendants        = false
    r.Parent                  = btn
    Instance.new("UICorner", r).CornerRadius = UDim.new(1, 0)
    TweenService:Create(r, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 260, 0, 260),
        BackgroundTransparency = 1,
    }):Play()
    task.delay(0.45, function()
        if r and r.Parent then r:Destroy() end
    end)
end

-- Generic button
local function MakeBtn(parent, text, bgColor, textColor, size, pos, zindex)
    local b = Instance.new("TextButton")
    b.Size             = size or UDim2.new(1, 0, 0, 38)
    b.Position         = pos  or UDim2.new(0, 0, 0, 0)
    b.BackgroundColor3 = bgColor
    b.TextColor3       = textColor or C.text
    b.Text             = text
    b.Font             = Enum.Font.GothamBold
    b.TextSize         = 13
    b.AutoButtonColor  = false
    b.BorderSizePixel  = 0
    b.ClipsDescendants = true
    b.ZIndex           = zindex or 5
    b.Parent           = parent
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
    local base = bgColor
    b.MouseButton1Down:Connect(function()
        MakeRipple(b)
        TweenService:Create(b, tweenFast, { BackgroundColor3 = base:Lerp(Color3.new(0,0,0), 0.2) }):Play()
    end)
    b.MouseButton1Up:Connect(function()
        TweenService:Create(b, tweenMed, { BackgroundColor3 = base }):Play()
    end)
    b.MouseEnter:Connect(function()
        TweenService:Create(b, tweenFast, { BackgroundColor3 = base:Lerp(Color3.new(1,1,1), 0.08) }):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b, tweenMed, { BackgroundColor3 = base }):Play()
    end)
    return b
end

